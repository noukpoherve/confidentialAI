# ── API Backend ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://confidentialai.koyeb.app

# ── Auth ──────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-32-random-chars-minimum

# ── Error tracking (GlitchTip via Sentry SDK) ─────────────────────────────────
# Leave empty in local — Sentry activates automatically only in production.
# Get your DSN at: app.glitchtip.com → your project → Settings → Client Keys
NEXT_PUBLIC_GLITCHTIP_DSN=
GLITCHTIP_DSN=
