{
  "manifest_version": 3,
  "name": "Confidential Agent Guardrail",
  "version": "0.1.0",
  "description": "DLP guardrail for generative AI prompts.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "http://localhost:8080/*",
    "http://127.0.0.1:8080/*",
    "https://confidentialai.koyeb.app/*"
  ],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": ["src/siteConfigs.js", "src/redactor.js", "src/contentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Confidential Agent",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
