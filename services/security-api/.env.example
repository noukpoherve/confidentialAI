# ─────────────────────────────────────────────────────────────────────────────
# Confidential Agent — Security API environment variables
# Copy this file to .env and fill in your values.
# The API loads all settings from environment variables at startup.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=confidential_agent
MONGODB_INCIDENTS_COLLECTION=incidents
MONGODB_USERS_COLLECTION=users
MONGODB_USER_SETTINGS_COLLECTION=user_settings
MONGODB_SITE_SIGNALS_COLLECTION=site_signals

# ── LLM Classifier (semantic + contextual detection) ─────────────────────────
#
# The LLM classifier adds a second detection layer on top of the regex engine.
# It catches what regex cannot: combinations of PII fields, paraphrased secrets,
# business-confidential context, and prompt injection attempts.
#
# HOW TO ACTIVATE:
#   Just set OPENAI_API_KEY (or LLM_CLASSIFIER_API_KEY) and the classifier
#   activates automatically — no need to also set LLM_CLASSIFIER_ENABLED.
#
# Compatible with any OpenAI-compatible endpoint (OpenAI, Azure OpenAI,
# local LM Studio, Ollama with OpenAI adapter, etc.).

OPENAI_API_KEY=sk-...                        # OpenAI key  → auto-enables classifier
# LLM_CLASSIFIER_API_KEY=sk-...             # Alternative: use a dedicated key
# LLM_CLASSIFIER_API_BASE=https://api.openai.com/v1   # Default: OpenAI. Change for Azure / local
# LLM_CLASSIFIER_MODEL=gpt-4.1-mini         # Default model — cheap + fast, good for classification
# LLM_CLASSIFIER_TIMEOUT_SECONDS=2.5        # Fail-open timeout: if LLM is slow, regex decision stands
# LLM_CLASSIFIER_ENABLED=true               # Explicit override (auto-set when key is present)

# ── Authentication (JWT) ──────────────────────────────────────────────────────
AUTH_SECRET_KEY=change-me-for-production-with-at-least-32-random-chars
# AUTH_ALGORITHM=HS256
# AUTH_ACCESS_TOKEN_MINUTES=120

# ── Telegram Alerts ───────────────────────────────────────────────────────────
# Optional: sends a Telegram message for every BLOCK or WARN decision.
# TELEGRAM_ALERTS_ENABLED=true
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id
# TELEGRAM_ALERT_ACTIONS=BLOCK,WARN

# ── Misc ──────────────────────────────────────────────────────────────────────
# INCIDENTS_LIST_LIMIT=100
# SITE_SIGNALS_LIST_LIMIT=200
